# ============================================
# 本番環境変数テンプレート
# docker-compose.prod.yml で使用
# ============================================
# コピーして .env として保存: cp .env.production.example .env
# シークレットは必ず変更してください

# --- PostgreSQL ---
POSTGRES_DB=helper_prod_db
POSTGRES_USER=helper_user
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_16

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_openssl_rand_hex_16

# --- Backend ---
JWT_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
CORS_ORIGINS=https://yourdomain.com
GUNICORN_WORKERS=4

# --- Domain ---
DOMAIN=yourdomain.com
