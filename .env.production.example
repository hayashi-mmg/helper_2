# ============================================
# 本番環境変数テンプレート
# docker-compose.prod.yml で使用
# ============================================
# コピーして .env として保存: cp .env.production.example .env
# シークレットは必ず変更してください

# --- PostgreSQL ---
POSTGRES_DB=helper_prod_db
POSTGRES_USER=helper_user
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_16

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_openssl_rand_hex_16

# --- Backend ---
JWT_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
CORS_ORIGINS=https://yourdomain.com
GUNICORN_WORKERS=4

# --- Ollama (AI献立提案) ---
# Dockerコンテナから見た Ollama の URL。WindowsホストのOllamaに接続する場合は host.docker.internal を使う
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_TIMEOUT_SECONDS=240

# --- Domain ---
DOMAIN=yourdomain.com

# --- Traefik ---
ACME_EMAIL=admin@yourdomain.com

# --- Backup (ローカル保存先) ---
# バックアップを書き出すローカルディレクトリ。書き込み権限が必要。
# root以外でデプロイしている場合はホームディレクトリ配下を推奨:
#   BACKUP_DIR=/home/<user>/backups
# 未指定時のデフォルトは /backups (root or chown 設定済みである前提)
BACKUP_DIR=

# --- Backup (オフサイトストレージ) ---
# Cloudflare R2 / Backblaze B2 等のS3互換ストレージに対応。
# AWS S3 を直接使う場合は BACKUP_S3_ENDPOINT_URL は未設定でよい。
#
# Cloudflare R2 の例:
#   AWS_S3_BUCKET=helper-backups-prod
#   BACKUP_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
#   AWS_PROFILE=r2
# (AWSアクセスキーは ~/.aws/credentials の [r2] プロファイルに設定)
AWS_S3_BUCKET=
BACKUP_S3_ENDPOINT_URL=
AWS_PROFILE=
BACKUP_RETENTION_DAYS=30

# --- Backup notifications ---
# Slack Incoming Webhook (成功・失敗どちらも通知)
SLACK_BACKUP_WEBHOOK_URL=
# 失敗時のみメール通知 (postfix / msmtp が必要)
BACKUP_ALERT_EMAIL=
